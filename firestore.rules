rules_version = '2';

// ---------------------------------------------------------------------------
// PLACEHOLDER — INFRASTRUCTURE PHASE ONLY.
// This file intentionally denies all client access. Definitive rules will be
// written from /docs/firestore-architecture.md once the data model and the
// per-collection access matrix are validated by the Product Owner.
// All reads/writes during this phase must go through the Admin SDK
// (trusted server context: Server Actions, Route Handlers, Cloud Functions),
// which bypasses these rules entirely.
// ---------------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
