rules_version = '2';

// ---------------------------------------------------------------------------
// Sprint 3 — flips the storefront-relevant collections from deny-all to the
// matrix already specified in docs/firestore-architecture.md §5. This is
// defense-in-depth, not a functional requirement: every read/write in this
// app already goes through the Admin SDK (Server Components/Actions/Route
// Handlers), which bypasses these rules entirely. Everything not explicitly
// listed below (inventory, suppliers, settings, auditLogs, stockMovements,
// incomingShipments, promotions, coupons, banners, homepage) stays deny-all
// until its own sprint defines the real access matrix.
// ---------------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Sprint 10A adds `support` (below staff) and `manager` (above staff) —
    // this stays a coarse, defense-in-depth allow-list (every real read in
    // this app goes through the Admin SDK, which bypasses these rules
    // entirely; see file header). The actual fine-grained capability matrix
    // (e.g. `support` only sees Orders/Returns in the admin UI) is enforced
    // application-side by `lib/permissions.ts`, not here.
    function isStaffOrAbove() {
      return isSignedIn() &&
        request.auth.token.role in ['support', 'staff', 'manager', 'admin', 'superAdmin'];
    }

    match /products/{productId} {
      allow read: if resource.data.status == 'published' || isStaffOrAbove();
      allow write: if false; // Admin SDK / staff only.
    }

    match /categories/{categoryId} {
      allow read: if resource.data.isActive == true || isStaffOrAbove();
      allow write: if false;
    }

    match /collections/{collectionId} {
      allow read: if resource.data.status == 'active' || isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 6 Phase 2 — public read (reviews are always shown), no
    // submission UI yet: writes stay Admin SDK only, same shape as products.
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      // The `role` field is server-only writable (Admin SDK) — never
      // trust a client-supplied role change, even from the owner.
      allow read: if isOwner(uid) || isStaffOrAbove();
      allow write: if isOwner(uid) &&
        request.resource.data.role == resource.data.role;

      match /addresses/{addressId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /carts/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /wishlists/{uid} {
      match /items/{productId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow write: if false; // Server Action / Cloud Function only.

      match /payments/{paymentId} {
        allow read: if isSignedIn() &&
          (get(/databases/$(database)/documents/orders/$(orderId)).data.userId
            == request.auth.uid || isStaffOrAbove());
        allow write: if false; // Payment webhook (Admin SDK) only.
      }
    }

    // Sprint 8 — coupon codes are a secret worth protecting (unlike the
    // public product/category/collection catalog): no customer-facing read.
    // Validation happens server-side via a Server Action (Admin SDK), which
    // bypasses rules entirely, same as every write in this file.
    match /coupons/{couponId} {
      allow read: if isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 8 — audit trail for the notification-dispatch abstraction
    // (features/notifications/dispatch.ts). No real email/SMS/push is sent
    // yet; this just records that an event was raised, for admin visibility.
    match /notificationLog/{logId} {
      allow read: if isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 8 — invoices are derived, immutable snapshots of an order at
    // payment-confirmation time. Same visibility as the order they belong to.
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow write: if false;
    }

    // Sprint 9 — unified activity log (error/payment/refund/coupon/
    // notification/admin_action). Supersedes the Sprint 8 `notificationLog`
    // block above for new writes; that block stays so any existing data
    // there remains readable (additive migration, nothing deleted).
    match /activityLog/{logId} {
      allow read: if isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 9 — same owner-or-staff visibility as `orders`.
    match /returns/{returnId} {
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isStaffOrAbove());
      allow write: if false; // Server Action (Admin SDK) only.
    }

    // Sprint 10A — CMS/settings singleton documents. `store` is public
    // (storefront header/footer/contact page need it); write is Admin SDK
    // only via staff-gated Server Actions, same discipline as every other
    // collection in this file.
    match /settings/store {
      allow read: if true;
      allow write: if false;
    }

    match /settings/shipping {
      allow read: if true; // Checkout needs the live fee/threshold/tax rate.
      allow write: if false;
    }

    match /settings/{domain} {
      // payment / notifications / security — internal only.
      allow read: if isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 10A — homepage hero + other placements.
    match /banners/{bannerId} {
      allow read: if resource.data.isActive == true || isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 10A — homepage section builder.
    match /homepage/{sectionId} {
      allow read: if resource.data.isActive == true || isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 10A — product brands.
    match /brands/{brandId} {
      allow read: if resource.data.isActive == true || isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 10A — internal upload tracking, no public read.
    match /mediaLibrary/{mediaId} {
      allow read: if isStaffOrAbove();
      allow write: if false;
    }

    // Sprint 10A — editable site content (About/Contact/FAQ/Legal/Shipping).
    match /content/{pageKey} {
      allow read: if true;
      allow write: if false;
    }

    // Sprint 10A — header/footer menu manager.
    match /menus/{menuId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
