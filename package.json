{
  "name": "mitchaella-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "emulators": "npx firebase-tools emulators:start --only auth,firestore,storage,functions",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
