# -----------------------------------------------------------------------------
# Mitchaella Store — Environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (gitignored) and fill in real values.
# NEVER commit `.env.local` or any file containing real secrets.
#
# Variable groups:
#   1. Firebase Client SDK   -> public, safe to ship to the browser (NEXT_PUBLIC_*)
#   2. Firebase Admin SDK    -> server-only secrets, used by Server Actions /
#                                Route Handlers via firebase/admin.ts
#   3. App configuration     -> misc runtime toggles
#
# Where to find Firebase values: Firebase Console > Project settings.
#   - Client values: "General" tab > "Your apps" > SDK setup and configuration.
#   - Admin values: "Service accounts" tab > "Generate new private key".
# -----------------------------------------------------------------------------

# --- 1. Firebase Client SDK (public — exposed to the browser) ---------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — only if Google Analytics is enabled on the Firebase project.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- 2. Firebase Admin SDK (server-only — NEVER prefix with NEXT_PUBLIC_) ---
# Service account credentials, used server-side by firebase/admin.ts and by
# Cloud Functions when running locally outside the Firebase runtime.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the "\n" sequences literal (do not insert real line breaks) — the app
# normalizes them at startup. Wrap the whole value in quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# --- 3. App configuration ----------------------------------------------------
# Public base URL of the deployed app (used for canonical links, share URLs,
# auth redirect callbacks, webhooks, etc.).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# When "true", the client SDK connects to local Firebase Emulators instead of
# the live project (see `firebase emulators:start`). Never set to "true" in
# a deployed environment.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# --- 4. Firebase App Check (prepared, not enforced yet) ----------------------
# Set to "true" only once a real reCAPTCHA v3 site key (below) is provisioned
# in Firebase Console > App Check. Leaving this "false" keeps App Check
# inactive without touching code — see docs/technical-recommendations.md.
NEXT_PUBLIC_ENABLE_APP_CHECK=false
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# --- 5. Reserved for future integrations (not yet wired — see docs) ---------
# Payment provider, transactional email, SMS/WhatsApp notifications, etc. are
# intentionally omitted until the corresponding feature module is scoped with
# the Product Owner. Add the provider's variables here when that decision is
# made, following the same NEXT_PUBLIC_ / server-only split as above.
